# ---------------------------------------------------------------------------
# .env.example — Copier en .env et adapter
# NE JAMAIS COMMITTER .env (il est dans .gitignore)
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Base de données PostgreSQL
# ---------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=abrid
DB_USER=abrid
DB_PASSWORD=changeme_secret
DB_POOL_SIZE=10
# Port exposé sur l'hôte (utile si 5432 est déjà utilisé)
DB_EXPOSED_PORT=5432

# ---------------------------------------------------------------------------
# Source GTFS
# ---------------------------------------------------------------------------
# URL du flux GTFS (ZIP). Laisser vide pour utiliser le flux communautaire par défaut.
GTFS_URL=https://github.com/newsbubbles/rail_maroc_oncf/raw/main/oncf_gtfs.zip

# Pour utiliser un fichier local pré-téléchargé (réseau restreint) :
# GTFS_URL=file:///app/data/oncf_gtfs.zip

# Désactiver la vérification SSL (dev/proxy corporate uniquement)
GTFS_SSL_TRUST_ALL=false

# Timeouts de téléchargement (secondes)
GTFS_CONNECT_TIMEOUT=30
GTFS_READ_TIMEOUT=120

# ---------------------------------------------------------------------------
# Proxy d'entreprise (optionnel)
# ---------------------------------------------------------------------------
# HTTP_PROXY=http://proxy.example.com:3128
# HTTPS_PROXY=http://proxy.example.com:3128
# NO_PROXY=localhost,127.0.0.1,db
# PROXY_USER=
# PROXY_PASSWORD=

# ---------------------------------------------------------------------------
# Comportement de l'application
# ---------------------------------------------------------------------------
# Ingestion au démarrage (worker one-shot)
INGEST_ON_STARTUP=false

# Mode worker : true = ingestion + exit, false = API longue durée
WORKER_MODE=false

# Respecter les dates du flux GTFS (false = mode dev, true = prod)
RESPECT_FEED_DATES=false

# Seuil minimum de couverture (%) pour accepter une ingestion
COVERAGE_THRESHOLD=50

# Cron d'ingestion périodique (format Spring : sec min heure jour mois jourSemaine)
# Défaut : 3h du matin chaque jour
WORKER_CRON=0 0 3 * * *

# ---------------------------------------------------------------------------
# Serveur
# ---------------------------------------------------------------------------
PORT=8080

# ---------------------------------------------------------------------------
# JVM (optionnel — tuning mémoire)
# ---------------------------------------------------------------------------
# JAVA_TOOL_OPTIONS=-Xmx512m -Xms256m

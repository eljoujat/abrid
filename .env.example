# Variables d'environnement — copier en .env et adapter

# Chemin de la base SQLite (dev)
DB_PATH=./data/oncf.db

# URL du flux GTFS (flux communautaire par défaut)
GTFS_URL=https://github.com/newsbubbles/rail_maroc_oncf/raw/main/oncf_gtfs.zip

# false en dev (ignore les bornes de date du flux), true en prod
RESPECT_FEED_DATES=false
